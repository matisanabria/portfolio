---
const education = [
  {
    title: "Ingeniería en Sistemas",
    institution: "Universidad",
    period: "2020 – 2024",
  },
  {
    title: "Curso de Desarrollo Web",
    institution: "Plataforma",
    period: "2023",
  },
];
---

<section id="educacion" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <h2 class="mb-12 text-3xl font-bold text-white">Educación</h2>
    <div class="space-y-8">
      {education.map((item) => (
        <div class="flex flex-col gap-1 border-l-2 border-zinc-800 pl-8">
          <p class="text-sm text-zinc-500">{item.period}</p>
          <h3 class="text-lg font-semibold text-white">{item.title}</h3>
          <p class="text-violet-400">{item.institution}</p>
        </div>
      ))}
    </div>
  </div>
</section>
