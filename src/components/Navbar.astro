---
const links = [
  { label: "Proyectos", href: "#proyectos" },
  { label: "Experiencia", href: "#experiencia" },
  { label: "Contacto", href: "#contacto" },
];
---

<nav
  class="sticky top-0 z-50 border-b border-line backdrop-blur-2xl"
  style="background: rgba(10, 10, 11, 0.85);"
>
  <div class="max-w-[960px] mx-auto px-6 md:px-12 h-14 flex items-center justify-between">
    <a href="#" class="font-display text-sm font-bold text-text no-underline tracking-tight">
      matisanabria
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-7">
      <ul class="flex list-none gap-1">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="font-mono text-[11px] tracking-wide text-muted no-underline px-3.5 py-1.5 rounded-md transition-colors duration-200 hover:text-text hover:bg-surface"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>

    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="flex md:hidden w-9 h-9 items-center justify-center rounded-md border border-line2 text-muted transition-colors duration-200 hover:text-text hover:border-muted cursor-pointer"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg id="icon-open" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
      <svg id="icon-close" class="hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden border-t border-line overflow-hidden grid transition-[grid-template-rows] duration-300 ease-out"
    style="grid-template-rows: 0fr; background: rgba(10, 10, 11, 0.95);"
  >
    <div class="min-h-0 overflow-hidden">
      <div class="max-w-[960px] mx-auto px-6 py-4 flex flex-col gap-1">
        {links.map((l) => (
          <a
            href={l.href}
            class="mobile-link font-mono text-sm tracking-wide text-muted no-underline px-4 py-3 rounded-md transition-colors duration-200 hover:text-text hover:bg-surface"
          >
            {l.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const iconOpen = document.getElementById("icon-open")!;
  const iconClose = document.getElementById("icon-close")!;
  const mobileLinks = menu.querySelectorAll(".mobile-link");

  let isOpen = false;

  function setOpen(open: boolean) {
    isOpen = open;
    menu.style.gridTemplateRows = open ? "1fr" : "0fr";
    iconOpen.classList.toggle("hidden", open);
    iconClose.classList.toggle("hidden", !open);
    toggle.setAttribute("aria-expanded", String(open));
  }

  toggle.addEventListener("click", () => setOpen(!isOpen));
  mobileLinks.forEach((link) => link.addEventListener("click", () => setOpen(false)));
</script>
