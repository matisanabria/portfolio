---
const projects = [
  {
    title: "Proyecto 1",
    description: "Breve descripción del proyecto y tecnologías usadas.",
    tags: ["Astro", "Tailwind"],
    link: "#",
  },
  {
    title: "Proyecto 2",
    description: "Breve descripción del proyecto y tecnologías usadas.",
    tags: ["React", "Node.js"],
    link: "#",
  },
  {
    title: "Proyecto 3",
    description: "Breve descripción del proyecto y tecnologías usadas.",
    tags: ["TypeScript", "PostgreSQL"],
    link: "#",
  },
];
---

<section id="proyectos" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <h2 class="mb-12 text-3xl font-bold text-white">Proyectos</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <a href={project.link} class="group rounded-xl border border-zinc-800 bg-zinc-900/50 p-6 hover:border-violet-500/50">
          <h3 class="text-lg font-semibold text-white">{project.title}</h3>
          <p class="mt-2 text-sm text-zinc-400">{project.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="rounded-full bg-zinc-800 px-3 py-1 text-xs text-zinc-300">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
