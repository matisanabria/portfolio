---
const jobs = [
  {
    role: "Full Stack Developer",
    company: "Empresa",
    period: "2024 – Presente",
    description: "Descripción del rol y responsabilidades principales.",
  },
  {
    role: "Frontend Developer",
    company: "Otra Empresa",
    period: "2023 – 2024",
    description: "Descripción del rol y responsabilidades principales.",
  },
];
---

<section id="experiencia" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <h2 class="mb-12 text-3xl font-bold text-white">Experiencia</h2>
    <div class="space-y-10">
      {jobs.map((job) => (
        <div class="border-l-2 border-zinc-800 pl-8">
          <p class="text-sm text-zinc-500">{job.period}</p>
          <h3 class="mt-1 text-xl font-semibold text-white">{job.role}</h3>
          <p class="text-violet-400">{job.company}</p>
          <p class="mt-3 text-zinc-400">{job.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
